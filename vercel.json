{
    "name": "personal-website",
    "version": 2,
    "cleanUrls": true,
    "redirects": [
        {
            "source": "/index.html",
            "destination": "/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "destination": "/pages/home.html"
        },
        {
            "source": "/admin",
            "destination": "/pages/admin.html"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        }
    ]
}